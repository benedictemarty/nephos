# Configuration Nephos — copier en .env (qui est git-ignoré) et adapter.
# Toutes les variables sont préfixées NEPHOS_ et matchent les champs de Settings.

# Connexion PostgreSQL (requis dès que les imports tournent).
NEPHOS_DATABASE_URL=postgresql://nephos:nephos@localhost:5432/nephos_dev

# Niveau et format des logs.
NEPHOS_LOG_LEVEL=INFO
NEPHOS_LOG_FORMAT=text   # 'text' (humain) ou 'json' (structuré)

# Dossier de travail pour caches et fichiers temporaires d'import.
NEPHOS_WORK_DIR=./var

# Préfixe canonique des URI Nephos (ADR 0003).
NEPHOS_URI_BASE=https://w3id.org/nephos/vocab
